{
    "name": "turnmark/scraper-tokuyama",
    "description": "Turnmark Scraper Tokuyama",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "boatrace",
        "library",
        "scraper",
        "tokuyama",
        "turnmark"
    ],
    "authors": [
        {
            "name": "shimomo",
            "email": "turnmark@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/turnmark/turnmark/issues",
        "source": "https://github.com/turnmark/turnmark"
    },
    "require": {
        "php": "^8.4",
        "turnmark/scraper": "^0.2.45"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Turnmark\\Scraper\\Tokuyama\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Turnmark\\Scraper\\Tokuyama\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "$schema": "https://getcomposer.org/schema.json"
}
