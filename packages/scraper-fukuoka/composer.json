{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "turnmark/scraper-fukuoka",
    "description": "Turnmark Scraper Fukuoka",
    "keywords": [
        "boatrace",
        "fukuoka",
        "library",
        "scraper",
        "turnmark"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "shimomo",
            "email": "turnmark@shimomo.net"
        }
    ],
    "support": {
        "issues": "https://github.com/turnmark/turnmark/issues",
        "source": "https://github.com/turnmark/turnmark"
    },
    "require": {
        "php": "^8.4",
        "turnmark/scraper": "^0.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "vimeo/psalm": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Turnmark\\Scraper\\Fukuoka\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Turnmark\\Scraper\\Fukuoka\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.3-dev"
        }
    }
}
